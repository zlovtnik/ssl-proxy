<% content_for :title, "Audit Windows" %>

<h1>Audit Windows</h1>
<p><%= link_to "New audit window", new_audit_window_path %></p>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th><%= sort_link_to "Location", :location_id %></th>
        <th><%= sort_link_to "Timezone", :timezone %></th>
        <th><%= sort_link_to "Days", :days %></th>
        <th><%= sort_link_to "Start", :start_time %></th>
        <th><%= sort_link_to "End", :end_time %></th>
        <th><%= sort_link_to "Enabled", :enabled %></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if @audit_windows.any? %>
        <% @audit_windows.each do |window| %>
          <tr>
            <td><%= window.location_id %></td>
            <td><%= window.timezone %></td>
            <td><%= window.days %></td>
            <td><%= window.start_time %></td>
            <td><%= window.end_time %></td>
            <td><%= window.enabled %></td>
            <td><%= link_to "Edit", edit_audit_window_path(window) %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="7" class="empty-state">No audit windows found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
