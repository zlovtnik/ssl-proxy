<h1>Identity Viewer</h1>

<%= form_with url: identities_path, method: :get do |form| %>
  <%= form.search_field :q, value: @query, placeholder: "Search MAC, username, SSID" %>
  <%= form.submit "Search" %>
<% end %>

<div class="table-wrap">
  <table>
    <thead><tr><th>Observed</th><th>Source MAC</th><th>BSSID</th><th>SSID</th><th>Username</th><th>Registered</th><th>Device</th></tr></thead>
    <tbody>
      <% @identities.each do |identity| %>
        <tr>
          <td><%= identity.observed_at %></td>
          <td><%= identity.source_mac %></td>
          <td><%= identity.bssid %></td>
          <td><%= identity.ssid %></td>
          <td><%= identity.username %></td>
          <td><%= identity.registered_username %></td>
          <td><%= identity.display_name || identity.device_id %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
