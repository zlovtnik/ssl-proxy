<% content_for :title, "Identities" %>
<% content_for :turbo_cache_control, "no-cache" %>

<h1>Identity Viewer</h1>

<p>
  <%= link_to "Inventory CSV", inventory_identities_path(request.query_parameters.merge(format: :csv)) %>
  |
  <%= link_to "Inventory JSON", inventory_identities_path(request.query_parameters.merge(format: :json)) %>
</p>

<%= form_with url: identities_path, method: :get do |form| %>
  <%= form.search_field :q, value: @query, placeholder: "Search MAC, username, SSID, fingerprint, WPS" %>
  <%= form.submit "Search" %>
<% end %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th><%= sort_link_to "Observed", :observed_at %></th>
        <th><%= sort_link_to "Source MAC", :source_mac %></th>
        <th><%= sort_link_to "BSSID", :bssid %></th>
        <th><%= sort_link_to "Dest BSSID", :destination_bssid %></th>
        <th><%= sort_link_to "SSID", :ssid %></th>
        <th><%= sort_link_to "Signal", :signal_dbm %></th>
        <th><%= sort_link_to "Username", :username %></th>
        <th><%= sort_link_to "Registered", :registered_username %></th>
        <th><%= sort_link_to "Device", :display_name %></th>
        <th><%= sort_link_to "WPS", :wps_device_name %></th>
        <th><%= sort_link_to "Fingerprint", :device_fingerprint %></th>
      </tr>
    </thead>
    <tbody>
      <% if @identities.any? %>
        <% @identities.each do |identity| %>
          <tr>
            <td><%= identity.observed_at %></td>
            <td><%= identity.source_mac %></td>
            <td><%= identity.bssid %></td>
            <td><%= identity.destination_bssid %></td>
            <td><%= identity.ssid %></td>
            <td><%= identity.signal_dbm %></td>
            <td><%= identity.username %></td>
            <td><%= identity.registered_username %></td>
            <td><%= identity.display_name || identity.device_id %></td>
            <td><%= identity.wps_device_name || identity.wps_model_name %></td>
            <td><%= identity.device_fingerprint&.first(12) %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="11" class="empty-state">No identities found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= render "shared/pagination" %>
</div>
