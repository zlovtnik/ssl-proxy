<% content_for :title, "Audit Logs" %>
<% content_for :turbo_cache_control, "no-cache" %>

<h1>Audit Logs</h1>

<%= form_with url: audit_logs_path, method: :get do |form| %>
  <%= form.search_field :q, value: @query, placeholder: "Search sensor, MAC, SSID, username" %>
  <%= form.submit "Search" %>
<% end %>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th><%= sort_link_to "Observed", :observed_at %></th>
        <th><%= sort_link_to "Sensor", :sensor_id %></th>
        <th><%= sort_link_to "Location", :location_id %></th>
        <th><%= sort_link_to "Subtype", :frame_subtype %></th>
        <th><%= sort_link_to "SSID", :ssid %></th>
        <th><%= sort_link_to "Source", :source_mac %></th>
        <th><%= sort_link_to "Signal", :signal_dbm %></th>
      </tr>
    </thead>
    <tbody>
      <% if @audit_logs.any? %>
        <% @audit_logs.each do |entry| %>
          <tr>
            <td><%= entry.observed_at %></td>
            <td><%= entry.sensor_id %></td>
            <td><%= entry.location_id %></td>
            <td><%= entry.frame_subtype %></td>
            <td><%= entry.ssid %></td>
            <td><%= display_mac(entry.source_mac) %></td>
            <td><%= entry.signal_dbm %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="7" class="empty-state">No audit logs found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= render "shared/pagination" %>
</div>
