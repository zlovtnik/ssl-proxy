<tr data-audit-log-id="<%= entry.dedupe_key %>" data-audit-log-observed-at="<%= entry.observed_at&.iso8601 %>">
  <td><%= link_to entry.observed_at, audit_log_path(entry) %></td>
  <td><%= entry.sensor_id %></td>
  <td><%= entry.location_id %></td>
  <td><%= entry.frame_subtype %></td>
  <td><%= entry.ssid %></td>
  <td><%= display_mac(entry.source_mac) %></td>
  <td><%= entry.signal_dbm %></td>
  <td><%= entry.compact_security_label || "open/unknown" %></td>
  <td><%= entry.device_fingerprint&.first(12) %></td>
  <td><%= entry.handshake_captured ? "captured" : "" %></td>
</tr>
