<!DOCTYPE html>
<html>
  <head>
    <title>Integration Console</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <main class="shell">
      <nav class="top-nav">
        <%= link_to "Health", root_path %>
        <%= link_to "Audit Logs", audit_logs_path %>
        <%= link_to "Backlog", backlog_index_path %>
        <%= link_to "Audit Windows", audit_windows_path %>
        <%= link_to "Identities", identities_path %>
        <%= link_to "Heatmap", heatmap_index_path %>
        <%= link_to "Alerts", alerts_path %>
      </nav>
      <% if notice.present? %><p class="status-ok"><%= notice %></p><% end %>
      <% if alert.present? %><p class="status-alert"><%= alert %></p><% end %>
      <%= yield %>
    </main>
  </body>
</html>
