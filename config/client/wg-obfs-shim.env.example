# Real remote server endpoint that the shim forwards to.
WG_OBFS_SERVER_ADDR=192.168.1.221:443

# Local endpoint that the WireGuard client points to.
WG_OBFS_SHIM_LISTEN_ADDR=127.0.0.1:51821

# Must match the server-side configuration exactly.
WG_OBFUSCATION_KEY=boringtun-obfuscation-key-change-me
WG_OBFUSCATION_MAGIC_BYTE=0xAA
WG_OBFUSCATION_SESSION_IDLE_SECS=300

# Optional logging override.
RUST_LOG=wg_obfs_shim=info
